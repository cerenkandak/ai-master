    "df = pd.DataFrame(senaryo)\n",
    "\n",
    "# --- GÖRSELLEŞTİRME ---\n",
    "fig, ax = plt.subplots(figsize=(12, 7))\n",
    "bar_width = 0.4\n",
    "index = range(len(df))\n",
