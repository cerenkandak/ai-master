    "import pandas as pd\n",
    "import random\n",
    "\n",
    "# Tablo çıktıları konsolda düzgün görünsün diye ayarlar\n",
    "pd.set_option('display.max_columns', None)\n",
    "pd.set_option('display.width', 1000)\n",
    "pd.set_option('display.colheader_justify', 'center')\n",
    "\n",
    "# --- 1. AŞAMA: SENTETİK VERİ SETİ OLUŞTURMA (HAM VERİ) ---\n",
    "def veri_tablosu_olustur(n=15):\n",
    "    veriler = []\n",
    "    cinsiyetler = [\"Kadin\", \"Erkek\"]\n",
    "    engel_durumlari = [\"Yok\", \"Var\"]\n",
    "    \n",
    "    for i in range(1, n + 1): \n",
    "        veriler.append({\n",
    "            \"Ogrenci_ID\": f\"ADAY-{1000+i}\",  # İsim yerine Anonim Kod\n",
    "            \"Gizli_Cinsiyet\": random.choice(cinsiyetler), # Etik test için var, hesaplamada YOK\n",
    "            \"Not_Ort (4.0)\": round(random.uniform(2.0, 4.0), 2),\n",
    "            \"Aile_Geliri_TL\": random.randrange(12000, 95000, 1000),\n",
    "            \"Engel_Durumu\": random.choices(engel_durumlari, weights=[80, 20], k=1)[0] # %20 ihtimalle var\n",
    "        })\n",
    "    \n",
    "    return pd.DataFrame(veriler)\n",
    "\n",
    "# --- 2. AŞAMA: ETİK PUANLAMA ALGORİTMASI ---\n",
    "def etik_hesaplama(df):\n",
    "    # Bu fonksiyon \"Gizli_Cinsiyet\" sütununa ASLA bakmaz (Bias Prevention)\n",
    "    \n",
    "    # A) Akademik Liyakat Puanı (Maksimum 40 Puan)\n",
    "    # Formül: (Not / 4.0) * 40\n",
    "    df['Puan_Akademik'] = round((df['Not_Ort (4.0)'] / 4.0) * 40, 1)\n",
    "    \n",
    "    # B) Sosyo-Ekonomik Adalet Puanı (Maksimum 50 Puan)\n",
    "    # Formül: Gelir arttıkça puan düşer. (Tavan limit 100.000 TL)\n",
    "    # Geliri düşük olanı yukarı taşır (Pozitif Ayrımcılık)\n",
    "    df['Puan_Sosyal'] = round((1 - (df['Aile_Geliri_TL'] / 100000)) * 50, 1)\n",
    "    \n",
    "    # C) Kapsayıcılık Puanı (Engel Durumu +10 Puan)\n",
    "    df['Puan_Engel'] = df['Engel_Durumu'].apply(lambda x: 10 if x == \"Var\" else 0)\n",
    "    \n",
    "    # D) TOPLAM VE KARAR\n",
    "    df['TOPLAM_SKOR'] = df['Puan_Akademik'] + df['Puan_Sosyal'] + df['Puan_Engel']\n",
    "    \n",
    "    # Baraj: 65 Puan\n",
    "    df['SONUC_KARAR'] = df['TOPLAM_SKOR'].apply(lambda x: \" KAZANDI\" if x >= 65 else \" RED\")\n",
    "    \n",
    "    return df\n",
