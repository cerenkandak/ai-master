    "# B) AÇIKLAYICI NOTLAR (Oklar ve Kutucuklar)\n",
    "# Mavi Kısım Notu\n",
    "ax.annotate('İki öğrenci de akademik\\nolarak EŞİT başarıda.',\n",
    "            xy=(0.5, 40), xycoords='data',\n",
    "            xytext=(0, -50), textcoords='offset points', ha='center',\n",
    "            arrowprops=dict(arrowstyle=\"->\", connectionstyle=\"arc3,rad=-0.2\", color='blue'),\n",
    "            bbox=dict(boxstyle=\"round,pad=0.3\", fc=\"white\", ec=\"blue\", lw=1))\n",
    "\n",
    "# Yeşil Kısım Notu\n",
    "ax.annotate('Algoritma, bu ek puan ile\\nFIRSAT EŞİTLİĞİ sağlar.\\nBarajı geçmesini mümkün kılar.',\n",
    "            xy=(1, 90), xycoords='data',\n",
    "            xytext=(50, 30), textcoords='offset points',\n",
    "            arrowprops=dict(arrowstyle=\"->\", connectionstyle=\"arc3\", color='green', lw=2),\n",
    "            bbox=dict(boxstyle=\"round,pad=0.3\", fc=\"#eaffea\", ec=\"green\", lw=1))\n",
    "\n",
    "# C) ETİKETLER VE BAŞLIKLAR (Hata veren yer burasıydı, düzeltildi)\n",
    "plt.xlabel('Öğrenci Profili', fontsize=13, fontweight='bold')\n",
    "plt.ylabel('Toplam Değerlendirme Puanı', fontsize=13, fontweight='bold')\n",
    "plt.title('EthicEval Analizi: Eşitlik (Equality) ile Adalet (Equity) Arasındaki Fark', fontsize=15, pad=20)\n",
    "\n",
    "plt.xticks(index, df['Öğrenci Tipi'], fontsize=11)\n",
    "plt.yticks(range(0, 130, 10))\n",
    "\n",
    "# Lejant Ayarı\n",
    "plt.legend(loc='upper left', bbox_to_anchor=(1, 1), title=\"Puan Bileşenleri\")\n",
    "\n",
    "# D) DEĞERLERİ YAZDIRMA\n",
    "# Mavi kısımlar\n",
    "plt.bar_label(p1, label_type='center', color='white', fontweight='bold', fontsize=12, fmt=\"+%.0f Puan\")\n",
    "# Yeşil kısım (Sadece 2. çubukta var)\n",
    "ax.text(1, 80 + 20/2, \"+20 Puan\\n(Destek)\", ha='center', va='center', color='black', fontweight='bold')\n",
    "# Toplam Puanlar\n",
    "for i in index:\n",
    "    plt.text(i, df['Toplam Puan'][i] + 3, f\"TOPLAM: {df['Toplam Puan'][i]}\", ha='center', fontweight='bold', fontsize=11, color='darkblue')\n",
    "\n",
    "plt.ylim(0, 135)\n",
    "plt.grid(axis='y', linestyle='--', alpha=0.6)\n",
    "plt.tight_layout()\n",
    "\n",
    "plt.show()"
