    "p2 = plt.bar(index, df['Adalet Destek Puanı'], bar_width, bottom=df['Akademik Puan'], label='Sosyo-Ekonomik Dengeleme (Adalet)', color='#2ecc71', alpha=0.9, edgecolor='black')\n",
