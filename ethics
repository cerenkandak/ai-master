    "import pandas as pd\n",
    "import random\n",
    "\n",
    "# Tablo çıktıları düzgün görünsün diye ayar\n",
    "pd.set_option('display.max_columns', None)\n",
    "pd.set_option('display.width', 1000)\n",
    "\n",
    "# 1. ADIM: SENTETİK VERİ TABLOSUNUN OLUŞTURULMASI\n",
    "# Burada 10 farklı öğrenci senaryosu üretiyoruz.\n",
    "def veri_tablosu_olustur():\n",
    "    veriler = []\n",
    "    \n",
    "    # Örnek olması için 10 öğrenci üretiyoruz\n",
    "    for i in range(1, 11): \n",
    "        veriler.append({\n",
    "            \"Ogrenci_ID\": f\"OGR-{100+i}\", # İsim yerine ID (Anonim)\n",
    "            \"Gizli_Cinsiyet\": random.choice([\"Kadin\", \"Erkek\"]), # Algoritmada KULLANILMAYACAK (Bias Testi İçin)\n",
    "            \"Not_Ortalamasi\": round(random.uniform(2.0, 4.0), 2), # 4.00 üzerinden\n",
    "            \"Aile_Geliri\": random.randrange(15000, 85000, 5000), # TL cinsinden\n",
    "            \"Engel_Durumu\": random.choice([\"Yok\", \"Yok\", \"Yok\", \"Var\"]) # %25 ihtimalle var\n",
    "        })\n",
    "    \n",
    "    return pd.DataFrame(veriler)\n",
    "\n",
    "# 2. ADIM: ALGORİTMANIN TABLOYU İŞLEMESİ\n",
    "def etik_puanlama(df):\n",
    "    # a) Akademik Puan Hesabı (4.0 -> 40 Puan)\n",
    "    df['Puan_Akademik'] = (df['Not_Ortalamasi'] / 4.0) * 40\n",
    "    \n",
    "    # b) Sosyo-Ekonomik Destek Puanı (Düşük Gelire Yüksek Puan)\n",
    "    # Formül: Gelir arttıkça puan düşer. (Max 50 Puan)\n",
    "    # 100.000 TL tavan limit kabul edilmiştir.\n",
    "    df['Puan_Sosyal'] = (1 - (df['Aile_Geliri'] / 100000)) * 50\n",
    "    \n",
    "    # c) Engel Durumu Desteği (Pozitif Ayrımcılık - 10 Puan)\n",
    "    df['Puan_Engel'] = df['Engel_Durumu'].apply(lambda x: 10 if x == \"Var\" else 0)\n",
    "    \n",
    "    # d) TOPLAM SONUÇ\n",
    "    df['TOPLAM_SKOR'] = df['Puan_Akademik'] + df['Puan_Sosyal'] + df['Puan_Engel']\n",
    "    \n",
    "    # e) KARAR (70 Puan Barajı)\n",
    "    df['KARAR'] = df['TOPLAM_SKOR'].apply(lambda x: \"KAZANDI\" if x > 70 else \"RED\")\n",
    "    \n",
    "    return df\n",
    "\n",
    "# --- KODU ÇALIŞTIRALIM ---\n",
    "\n",
    "# 1. Tabloyu Üret\n",
    "ham_tablo = veri_tablosu_olustur()\n",
    "print(\"--- 1. ADIM: SİSTEME GİREN HAM VERİ SETİ ---\")\n",
    "print(ham_tablo)\n",
    "print(\"\\n\" + \"=\"*80 + \"\\n\")\n",
    "\n",
    "# 2. İşle ve Sonucu Göster\n",
    "sonuc_tablosu = etik_puanlama(ham_tablo)\n",
    "\n",
    "# Raporda göstermek için: Cinsiyet sütununu (etik gereği) sonuçta göstermiyoruz\n",
    "final_gorunum = sonuc_tablosu.drop(columns=['Gizli_Cinsiyet'])\n",
    "\n",
    "print(\"--- 2. ADIM: ALGORİTMA SONRASI OLUŞAN KARAR TABLOSU ---\")\n",
    "print(final_gorunum.to_string(index=False))"
   ]
