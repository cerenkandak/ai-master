    "# A) BURS BARAJI ÇİZGİSİ\n",
    "baraj_puani = 90\n",
    "plt.axhline(y=baraj_puani, color='red', linestyle='--', linewidth=2, label=f'Burs Kazanma Barajı ({baraj_puani} Puan)')\n",
