    "# ─────────────────────────────────────────\n",
    "# 4. FİZİKSEL SİMÜLASYON\n",
    "# ─────────────────────────────────────────\n",
    " \n",
    "def simulate(theta0=15.0, theta_dot0=0.0, dt=0.02, T=10.0):\n",
    "    \"\"\"\n",
    "    Ters sarkaç dinamiği:\n",
    "    θ̈ = (g·sinθ - cos θ · F/M_total) / (L · (4/3 - m·cos²θ/M_total))\n",
    "    (basitleştirilmiş model: araba+sarkaç)\n",
    "    \"\"\"\n",
    "    g   = 9.81    # m/s²\n",
    "    m   = 0.1     # çubuk kütlesi (kg)\n",
    "    M   = 1.0     # araba kütlesi (kg)\n",
    "    L   = 0.5     # çubuk yarı uzunluğu (m)\n",
    "    Mt  = m + M\n",
    " \n",
    "    steps = int(T / dt)\n",
    "    theta     = np.zeros(steps)\n",
    "    theta_dot = np.zeros(steps)\n",
    "    forces    = np.zeros(steps)\n",
    "    time      = np.linspace(0, T, steps)\n",
    " \n",
    "    theta[0]     = theta0\n",
    "    theta_dot[0] = theta_dot0\n",
    " \n",
    "    for k in range(steps - 1):\n",
    "        th  = theta[k]\n",
    "        thd = theta_dot[k]\n",
    " \n",
    "        # Kontrol kuvveti (derece → radyan dönüşümü içeride)\n",
    "        F = mamdani_infer(th, thd)\n",
    "        F = np.clip(F, -100, 100)\n",
    "        forces[k] = F\n",
    " \n",
    "        # Radyana çevir\n",
    "        th_rad = np.radians(th)\n",
    " \n",
    "        # Açısal ivme\n",
    "        num = g * np.sin(th_rad) - np.cos(th_rad) * F / Mt\n",
    "        den = L * (4/3 - m * np.cos(th_rad)**2 / Mt)\n",
    "        theta_ddot = num / den\n",
    " \n",
    "        # Euler integrasyonu\n",
    "        theta_dot[k+1] = thd + np.degrees(theta_ddot) * dt\n",
    "        theta[k+1]     = th  + theta_dot[k+1] * dt\n",
    " \n",
    "        # Sınır kontrolü\n",
    "        if abs(theta[k+1]) > 85:\n",
    "            theta[k+1:] = theta[k+1]\n",
    "            forces[k+1:] = 0\n",
    "            break\n",
    " \n",
    "    forces[-1] = forces[-2]\n",
    "    return time, theta, theta_dot, forces"
   ]
