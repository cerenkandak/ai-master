    "# ─── Kuvvet (force) üyelik fonksiyonları ───\n",
    "def mf_force(x):\n",
    "    NB = trapmf(x, -100, -100, -70, -40)\n",
    "    NM = trimf(x,  -70,  -40,   0)\n",
    "    ZE = trimf(x,  -25,    0,  25)\n",
    "    PM = trimf(x,    0,   40,  70)\n",
    "    PB = trapmf(x,   40,  70, 100, 100)\n",
    "    return NB, NM, ZE, PM, PB"
