   "source": [
    "# ─── Açısal hız (theta_dot) üyelik fonksiyonları ───\n",
    "def mf_theta_dot(x):\n",
    "    NB = trapmf(x, -50, -50, -30, -15)\n",
    "    NM = trimf(x, -30, -15,   0)\n",
    "    ZE = trimf(x, -12,   0,  12)\n",
    "    PM = trimf(x,   0,  15,  30)\n",
    "    PB = trapmf(x,  15,  30,  50, 50)\n",
    "    return NB, NM, ZE, PM, PB\n",
    " "
