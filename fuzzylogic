    "# ─── Açı (theta) üyelik fonksiyonları ───\n",
    "def mf_theta(x):\n",
    "    NB = trapmf(x, -30, -30, -20, -10)   # Negatif Büyük\n",
    "    NM = trimf(x, -20, -10,   0)          # Negatif Orta\n",
    "    ZE = trimf(x, -8,    0,   8)          # Sıfır\n",
    "    PM = trimf(x,   0,  10,  20)          # Pozitif Orta\n",
    "    PB = trapmf(x,  10,  20,  30, 30)    # Pozitif Büyük\n",
    "    return NB, NM, ZE, PM, PB"
   ]
