    "def mamdani_infer(theta_val, theta_dot_val):\n",
    "    x_t  = np.array([theta_val])\n",
    "    x_td = np.array([theta_dot_val])\n",
    "    t_mf  = mf_theta(x_t)\n",
    "    td_mf = mf_theta_dot(x_td)\n",
    "\n",
    "    t_vals  = [float(m[0]) for m in t_mf]\n",
    "    td_vals = [float(m[0]) for m in td_mf]\n",
    "\n",
    "    f_mfs = list(mf_force(force_range))\n",
    "\n",
    "    agg = np.zeros_like(force_range)\n",
    "\n",
    "    for i in range(5):\n",
    "        for j in range(5):\n",
    "            firing = min(t_vals[i], td_vals[j])\n",
    "            if firing > 0:\n",
    "                out_idx = RULE_TABLE[i][j]\n",
    "                clipped = np.minimum(firing, f_mfs[out_idx])\n",
    "                agg = np.maximum(agg, clipped)\n",
    "\n",
    "    # Durulama – Centroid\n",
    "    denom = np.sum(agg)\n",
    "    if denom < 1e-10:\n",
    "        return 0.0\n",
    "    force = np.sum(force_range * agg) / denom\n",
    "    return float(force)"
   ]
