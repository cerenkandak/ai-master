   "outputs": [],
   "source": [
    "RULE_TABLE = [\n",
    "    # NB  NM  ZE  PM  PB  (theta_dot)\n",
    "    [  0,  0,  1,  1,  2],  # theta = NB\n",
    "    [  0,  1,  1,  2,  3],  # theta = NM\n",
    "    [  1,  1,  2,  3,  3],  # theta = ZE\n",
    "    [  1,  2,  3,  3,  4],  # theta = PM\n",
    "    [  2,  3,  3,  4,  4],  # theta = PB\n",
    "]\n",
    "# 0=NB, 1=NM, 2=ZE, 3=PM, 4=PB"
   ]
