    "# ─────────────────────────────────────────\n",
    "# 2. KURAL TABANI (25 Kural - 5x5)\n",
    "# ─────────────────────────────────────────\n",
    "#\n",
    "# theta\\theta_dot  NB   NM   ZE   PM   PB\n",
    "#      NB          NB   NB   NM   NM   ZE\n",
    "#      NM          NB   NM   NM   ZE   PM\n",
    "#      ZE          NM   NM   ZE   PM   PM\n",
    "#      PM          NM   ZE   PM   PM   PB\n",
    "#      PB          ZE   PM   PM   PB   PB\n",
    "#\n",
    "# Sezgisel: Sarkaç sağa yatıksa → sağa kuvvet uygula"
   ]
