    "# ─────────────────────────────────────────\n",
    "# 1. ÜYELİK FONKSİYONLARI\n",
    "# ─────────────────────────────────────────\n",
    " \n",
    "def trimf(x, a, b, c):\n",
    "    \"\"\"Üçgen üyelik fonksiyonu\"\"\"\n",
    "    return np.maximum(0, np.minimum((x - a) / (b - a + 1e-10),\n",
    "                                    (c - x) / (c - b + 1e-10)))\n",
    " \n",
    "def trapmf(x, a, b, c, d):\n",
    "    \"\"\"Trapez üyelik fonksiyonu\"\"\"\n",
    "    return np.maximum(0, np.minimum(np.minimum((x - a) / (b - a + 1e-10), 1),\n",
    "                                    (d - x) / (d - c + 1e-10)))\n",
    " "
   ]
